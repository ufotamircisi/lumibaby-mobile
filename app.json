{
  "expo": {
    "name": "LumiBaby",
    "slug": "LumiBaby",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lumibaby",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Bebeğinizin ağlamasını analiz etmek için mikrofon gereklidir.",
        "UIBackgroundModes": [
          "audio",
          "remote-notification"
        ]
      }
    },
    "android": {
      "permissions": [
        "RECORD_AUDIO",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#07101e",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#07101e"
        }
      ],
      "expo-audio",
      [
        "expo-av",
        {
          "microphonePermission": "Bebeğinizin ağlamasını analiz etmek için mikrofon gereklidir."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#9d8cef",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "LumiBaby"
        }
      ],
      "expo-font",
      "expo-asset",
      "expo-web-browser",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-9989976581430768~3083871670",
          "iosAppId": "ca-app-pub-9989976581430768~6639973309",
          "tagForChildDirectedTreatment": false,
          "tagForUnderAgeOfConsent": false,
          "maxAdContentRating": "PG"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
